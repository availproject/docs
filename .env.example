# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# GitHub token for the feedback widget (creates issues on user feedback)
# Requires `repo` scope for private repos, or use a fine-grained PAT with Issues read/write
GITHUB_FEEDBACK_TOKEN=

# Vercel Blob storage for feedback screenshots
# Create a blob store in Vercel dashboard → Storage tab
BLOB_READ_WRITE_TOKEN=
