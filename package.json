{
  "name": "fumadocs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "lint:staged": "lint-staged",
    "validate:precommit": "pnpm lint:staged && pnpm types:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write",
    "redirects:crawl-old": "node scripts/crawl-old-docs.mjs",
    "redirects:list-new": "node scripts/list-new-docs.mjs",
    "redirects:generate": "node scripts/generate-redirects.mjs",
    "redirects:report": "node scripts/generate-redirects-report.mjs",
    "links:validate": "node scripts/validate-internal-links.mjs",
    "links:fix": "node scripts/validate-internal-links.mjs --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@avail-project/nexus-core": "github:availproject/nexus-sdk#fix/bigint-issue-fix",
    "@phosphor-icons/react": "2.1.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "connectkit": "^1.9.1",
    "front-matter": "^4.0.2",
    "fumadocs-core": "16.4.0",
    "fumadocs-mdx": "14.2.2",
    "fumadocs-ui": "16.4.0",
    "geist": "1.7.0",
    "lucide-react": "^0.561.0",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.336.4",
    "radix-ui": "1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rehype-pretty-code": "^0.14.1",
    "shiki": "^3.21.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "viem": "~2.45.0",
    "wagmi": "^3.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/jest": "^30.0.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,mdx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
